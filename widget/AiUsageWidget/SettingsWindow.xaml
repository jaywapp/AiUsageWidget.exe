<Window x:Class="AiUsageWidget.SettingsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="위젯 설정" Width="270" Height="252"
        WindowStyle="None" AllowsTransparency="True" Background="Transparent"
        WindowStartupLocation="CenterOwner" ResizeMode="NoResize"
        ShowInTaskbar="False" Topmost="True">
  <Window.Resources>
    <Style TargetType="TextBox">
      <Setter Property="Background" Value="#0C0E14"/>
      <Setter Property="Foreground" Value="#E8EAF0"/>
      <Setter Property="BorderBrush" Value="#2A2F3E"/>
      <Setter Property="BorderThickness" Value="1"/>
      <Setter Property="Padding" Value="6,4"/>
      <Setter Property="FontSize" Value="12"/>
      <Setter Property="VerticalContentAlignment" Value="Center"/>
      <Setter Property="CaretBrush" Value="#E8EAF0"/>
    </Style>
    <Style TargetType="Button">
      <Setter Property="Background" Value="#2A2F3E"/>
      <Setter Property="Foreground" Value="#E8EAF0"/>
      <Setter Property="BorderThickness" Value="0"/>
      <Setter Property="Padding" Value="14,6"/>
      <Setter Property="FontSize" Value="12"/>
      <Setter Property="Cursor" Value="Hand"/>
    </Style>
    <Style TargetType="TextBlock" x:Key="FieldLabel">
      <Setter Property="Foreground" Value="#8B91A3"/>
      <Setter Property="FontSize" Value="11"/>
      <Setter Property="VerticalAlignment" Value="Center"/>
    </Style>
  </Window.Resources>
  <Border Background="#FA141621" CornerRadius="12" BorderBrush="#2A2F3E" BorderThickness="1" Padding="18,14">
    <StackPanel>
      <TextBlock Text="위젯 설정" FontWeight="Bold" FontSize="13" Foreground="#E8EAF0" Margin="0,0,0,12"/>

      <Grid Margin="0,0,0,8">
        <Grid.ColumnDefinitions>
          <ColumnDefinition Width="100"/>
          <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>
        <TextBlock Grid.Column="0" Text="너비 (px)" Style="{StaticResource FieldLabel}"/>
        <TextBox x:Name="WidthBox" Grid.Column="1"/>
      </Grid>

      <Grid Margin="0,0,0,8">
        <Grid.ColumnDefinitions>
          <ColumnDefinition Width="100"/>
          <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>
        <TextBlock Grid.Column="0" Text="높이 (px)" Style="{StaticResource FieldLabel}"/>
        <TextBox x:Name="HeightBox" Grid.Column="1"/>
      </Grid>

      <Grid Margin="0,0,0,4">
        <Grid.ColumnDefinitions>
          <ColumnDefinition Width="100"/>
          <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>
        <TextBlock Grid.Column="0" Text="갱신 주기 (초)" Style="{StaticResource FieldLabel}"/>
        <TextBox x:Name="RefreshBox" Grid.Column="1"/>
      </Grid>

      <TextBlock x:Name="ErrorText" Text="" FontSize="10.5" Foreground="#E0564F" Margin="0,2,0,4" TextWrapping="Wrap"/>

      <Grid Margin="0,6,0,0">
        <Grid.ColumnDefinitions>
          <ColumnDefinition Width="*"/>
          <ColumnDefinition Width="Auto"/>
          <ColumnDefinition Width="8"/>
          <ColumnDefinition Width="Auto"/>
        </Grid.ColumnDefinitions>
        <Button x:Name="OkButton" Grid.Column="1" Content="확인" Click="Ok_Click" Background="#D97757"/>
        <Button x:Name="CancelButton" Grid.Column="3" Content="취소" Click="Cancel_Click"/>
      </Grid>
    </StackPanel>
  </Border>
</Window>
